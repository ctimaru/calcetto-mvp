# Supabase Configuration
# Get these from https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe Configuration (Optional - required for payment functionality)
# Get this from https://dashboard.stripe.com → Developers → API keys
# Use the Publishable key (starts with pk_test_ or pk_live_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
