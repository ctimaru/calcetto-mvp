# Supabase Configuration
# Get these values from your Supabase Dashboard: https://supabase.com/dashboard
# Navigate to: Settings → API

# Your Supabase project URL (starts with https://)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (long JWT token)
# ⚠️ Use the ANON key, NOT the service_role key
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-actual-key-here
